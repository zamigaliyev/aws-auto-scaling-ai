# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# Auto Scaling Configuration
AUTO_SCALING_GROUP_NAME=autoscale-ai-asg
MIN_INSTANCES=1
MAX_INSTANCES=20
DESIRED_CAPACITY=2

# CloudWatch Configuration
CLOUDWATCH_NAMESPACE=AutoScaleAI/Metrics
CPU_SCALE_OUT_THRESHOLD=80.0
CPU_SCALE_IN_THRESHOLD=20.0
MEMORY_SCALE_OUT_THRESHOLD=85.0
ALARM_EVALUATION_PERIODS=2
ALARM_PERIOD_SECONDS=300

# ML Model Configuration
MODEL_RETRAIN_INTERVAL_HOURS=6
PREDICTION_HORIZON_HOURS=2
ANOMALY_CONTAMINATION=0.05
MIN_TRAINING_SAMPLES=100

# Application
APP_NAME=AutoScaleAI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# Cost Optimization
COST_PER_INSTANCE_HOUR=0.096
SCALE_IN_COOLDOWN_SECONDS=300
SCALE_OUT_COOLDOWN_SECONDS=180
